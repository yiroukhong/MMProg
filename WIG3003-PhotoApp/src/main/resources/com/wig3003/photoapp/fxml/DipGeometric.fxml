<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.canvas.Canvas?>

<!--
    DipGeometric.fxml  –  WIG3003 PhotoApp Geometric Transformation Module
    =========================================================================
    FIXES vs original:
      • onAction method names now match DipGeometricController exactly
          handleReset  (was resetAll)
          handleUndo   (was undo)
      • Viewer zoom ComboBox added to toolbar
      • Status bar has fx:id so controller can update it
      • Toolbar "Save to Both" button added
      • Minor layout polish (consistent spacing)
-->

<VBox xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.wig3003.photoapp.dip.geometric.DipGeometricController"
      spacing="0"
      style="-fx-background-color:#1a1612;">

    <!-- ═══════════════════════════════════════════════════════
         TOP TOOLBAR
    ═══════════════════════════════════════════════════════ -->
    <HBox spacing="8"
          alignment="CENTER_LEFT"
          style="-fx-padding:0 14;
                 -fx-min-height:46;
                 -fx-max-height:46;
                 -fx-background-color:#161210;
                 -fx-border-color:#2c2620;
                 -fx-border-width:0 0 1 0;">

        <!-- Load from device -->
        <Button text="Load File"
                onAction="#loadImage"
                style="-fx-font-size:11;
                       -fx-font-weight:bold;
                       -fx-background-color:#c86442;
                       -fx-text-fill:white;
                       -fx-padding:6 16;
                       -fx-background-radius:6;
                       -fx-cursor:hand;"/>

        <!-- Load from library -->
        <Button text="Load Library"
                onAction="#loadFromLibrary"
                style="-fx-font-size:11;
                       -fx-font-weight:bold;
                       -fx-background-color:#7a5c3a;
                       -fx-text-fill:white;
                       -fx-padding:6 14;
                       -fx-background-radius:6;
                       -fx-cursor:hand;"/>

        <Separator orientation="VERTICAL"
                   style="-fx-opacity:0.25;"/>

        <!-- Save group -->
        <Button text="Save to Library"
                onAction="#saveToLibrary"
                style="-fx-font-size:11;
                       -fx-background-color:rgba(255,255,255,0.08);
                       -fx-text-fill:rgba(240,230,216,0.8);
                       -fx-padding:6 14;
                       -fx-background-radius:6;
                       -fx-cursor:hand;"/>

        <Button text="Save to Device"
                onAction="#saveResult"
                style="-fx-font-size:11;
                       -fx-background-color:rgba(255,255,255,0.08);
                       -fx-text-fill:rgba(240,230,216,0.8);
                       -fx-padding:6 14;
                       -fx-background-radius:6;
                       -fx-cursor:hand;"/>

        <Button text="Save Both"
                onAction="#saveBoth"
                style="-fx-font-size:11;
                       -fx-background-color:rgba(255,255,255,0.08);
                       -fx-text-fill:rgba(240,230,216,0.8);
                       -fx-padding:6 14;
                       -fx-background-radius:6;
                       -fx-cursor:hand;"/>

        <Separator orientation="VERTICAL"
                   style="-fx-opacity:0.25;"/>

        <!-- Edit history -->
        <Button fx:id="undoBtn"
                text="Undo"
                onAction="#handleUndo"
                style="-fx-font-size:11;
                       -fx-background-color:rgba(255,255,255,0.06);
                       -fx-text-fill:rgba(240,230,216,0.55);
                       -fx-padding:6 14;
                       -fx-background-radius:6;
                       -fx-cursor:hand;"/>

        <Button text="Reset"
                onAction="#handleReset"
                style="-fx-font-size:11;
                       -fx-background-color:rgba(255,255,255,0.06);
                       -fx-text-fill:rgba(240,230,216,0.55);
                       -fx-padding:6 14;
                       -fx-background-radius:6;
                       -fx-cursor:hand;"/>

        <Region HBox.hgrow="ALWAYS"/>

        <!-- Viewer zoom selector – labels must match SmartViewport.PRESET_LABELS -->
        <Label text="Zoom"
               style="-fx-font-size:10;
                      -fx-text-fill:white;
                      -fx-font-weight:bold;"/>

        <ComboBox fx:id="zoomCombo"
                  onAction="#handleZoomChange"
                  prefWidth="116"
                  style="-fx-font-size:11;
                         -fx-background-color:#f0ebe4;
                         -fx-text-fill:#1a1208;
                         -fx-border-color:#c8b89a;
                         -fx-border-radius:5;
                         -fx-background-radius:5;"/>

        <Separator orientation="VERTICAL"
                   style="-fx-opacity:0.25;"/>

        <!-- Status -->
        <Label fx:id="statusBar"
               text="No image loaded."
               style="-fx-font-size:10;
                      -fx-text-fill:rgba(240,230,216,0.35);
                      -fx-font-family:'Consolas',monospace;
                      -fx-max-width:300;"/>
    </HBox>

    <!-- ═══════════════════════════════════════════════════════
         MAIN BODY
    ═══════════════════════════════════════════════════════ -->
    <HBox VBox.vgrow="ALWAYS">

        <!-- ── LEFT: IMAGE VIEWER ── -->
        <StackPane HBox.hgrow="ALWAYS"
                   style="-fx-background-color:#1a1a1a;">

            <ScrollPane fx:id="resultScrollPane"
                        pannable="true"
                        fitToWidth="true"
                        fitToHeight="true"
                        hbarPolicy="AS_NEEDED"
                        vbarPolicy="AS_NEEDED"
                        style="-fx-background-color:#1a1a1a;
                               -fx-background:#1a1a1a;
                               -fx-border-color:transparent;
                               -fx-focus-color:transparent;
                               -fx-faint-focus-color:transparent;">

                <!-- Centred pane: checker canvas + image stacked -->
                <StackPane fx:id="resultCheckerPane"
                           style="-fx-background-color:transparent;">

                    <!-- Checkerboard drawn by controller – always visible -->
                    <Canvas fx:id="checkerCanvas"
                            mouseTransparent="true"/>

                    <!-- The actual image display -->
                    <ImageView fx:id="resultView"
                               preserveRatio="true"
                               smooth="true"
                               pickOnBounds="false"/>

                    <!-- Placeholder when no image is loaded -->
                    <Label fx:id="resultLabel"
                           text="Load an image to begin"
                           StackPane.alignment="CENTER"
                           style="-fx-font-size:13;
                                  -fx-text-fill:rgba(255,255,255,0.25);
                                  -fx-font-family:'Georgia',serif;"/>
                </StackPane>
            </ScrollPane>
        </StackPane>

        <!-- ── RIGHT: CONTROL PANEL ── -->
        <VBox prefWidth="282"
              minWidth="260"
              maxWidth="300"
              style="-fx-background-color:#faf6f1;
                     -fx-border-color:#e8dfd4;
                     -fx-border-width:0 0 0 1;">

            <ScrollPane fitToWidth="true"
                        VBox.vgrow="ALWAYS"
                        style="-fx-background-color:#faf6f1;
                               -fx-border-color:transparent;
                               -fx-focus-color:transparent;
                               -fx-faint-focus-color:transparent;">

                <VBox spacing="0">

                    <!-- ══════════════════════════════════════════
                         SCALE SECTION
                    ══════════════════════════════════════════ -->
                    <VBox style="-fx-padding:16;
                                 -fx-border-color:#e8dfd4;
                                 -fx-border-width:0 0 1 0;">

                        <Label text="Scale"
                               style="-fx-font-size:12;
                                      -fx-font-weight:bold;
                                      -fx-text-fill:#1f1b16;
                                      -fx-font-family:'Georgia',serif;
                                      -fx-padding:0 0 10 0;"/>

                        <!-- Slider + value label -->
                        <HBox spacing="8" alignment="CENTER_LEFT">

                            <Slider fx:id="scaleSlider"
                                    min="10" max="300" value="100"
                                    HBox.hgrow="ALWAYS"
                                    showTickMarks="true"
                                    showTickLabels="true"
                                    majorTickUnit="50"
                                    blockIncrement="5"/>

                            <Label fx:id="scaleValueLabel"
                                   text="100%"
                                   style="-fx-font-size:11;
                                          -fx-font-weight:bold;
                                          -fx-text-fill:#c86442;
                                          -fx-min-width:44;"/>
                        </HBox>

                        <!-- W / H input + Apply -->
                        <HBox spacing="6" alignment="CENTER_LEFT"
                              style="-fx-padding:8 0 0 0;">

                            <Label text="W"
                                   style="-fx-font-size:10; -fx-font-weight:bold;"/>

                            <TextField fx:id="resizeW"
                                       prefWidth="64" prefHeight="28"
                                       promptText="px"/>

                            <Label text="H"
                                   style="-fx-font-size:10; -fx-font-weight:bold;"/>

                            <TextField fx:id="resizeH"
                                       prefWidth="64" prefHeight="28"
                                       promptText="px"/>

                            <Button text="Apply"
                                    onAction="#applyResize"
                                    prefHeight="28"
                                    HBox.hgrow="ALWAYS"
                                    maxWidth="Infinity"
                                    style="-fx-font-size:10;
                                           -fx-font-weight:bold;
                                           -fx-background-color:#c86442;
                                           -fx-text-fill:white;
                                           -fx-background-radius:5;
                                           -fx-cursor:hand;"/>
                        </HBox>

                        <!-- Aspect lock -->
                        <CheckBox fx:id="lockAspect"
                                  text="Lock aspect ratio"
                                  selected="true"
                                  style="-fx-font-size:10;
                                         -fx-padding:6 0 0 0;"/>
                    </VBox>

                    <!-- ══════════════════════════════════════════
                         ROTATION SECTION
                    ══════════════════════════════════════════ -->
                    <VBox style="-fx-padding:16;
                                 -fx-border-color:#e8dfd4;
                                 -fx-border-width:0 0 1 0;">

                        <Label text="Rotation"
                               style="-fx-font-size:12;
                                      -fx-font-weight:bold;
                                      -fx-text-fill:#1f1b16;
                                      -fx-font-family:'Georgia',serif;
                                      -fx-padding:0 0 10 0;"/>

                        <HBox spacing="8" alignment="CENTER_LEFT">

                            <Slider fx:id="rotateSlider"
                                    min="-180" max="180" value="0"
                                    HBox.hgrow="ALWAYS"
                                    showTickMarks="true"
                                    showTickLabels="true"
                                    majorTickUnit="45"
                                    blockIncrement="1"/>

                            <Label fx:id="rotateValueLabel"
                                   text="0.0°"
                                   style="-fx-font-size:11;
                                          -fx-font-weight:bold;
                                          -fx-text-fill:#c86442;
                                          -fx-min-width:48;"/>
                        </HBox>

                        <HBox spacing="6" alignment="CENTER_LEFT"
                              style="-fx-padding:8 0 0 0;">

                            <TextField fx:id="rotateField"
                                       prefWidth="80" prefHeight="28"
                                       promptText="0.0"/>

                            <Label text="°"/>

                            <Region HBox.hgrow="ALWAYS"/>

                            <Button text="Apply"
                                    onAction="#applyRotate"
                                    prefHeight="28" prefWidth="70"
                                    style="-fx-font-size:10;
                                           -fx-font-weight:bold;
                                           -fx-background-color:#c86442;
                                           -fx-text-fill:white;
                                           -fx-background-radius:5;
                                           -fx-cursor:hand;"/>
                        </HBox>
                    </VBox>

                    <!-- ══════════════════════════════════════════
                         TRANSLATION SECTION
                    ══════════════════════════════════════════ -->
                    <VBox style="-fx-padding:16;
                                 -fx-border-color:#e8dfd4;
                                 -fx-border-width:0 0 1 0;">

                        <Label text="Translate"
                               style="-fx-font-size:12;
                                      -fx-font-weight:bold;
                                      -fx-text-fill:#1f1b16;
                                      -fx-font-family:'Georgia',serif;
                                      -fx-padding:0 0 10 0;"/>

                        <!-- X axis -->
                        <HBox spacing="8" alignment="CENTER_LEFT"
                              style="-fx-padding:0 0 6 0;">

                            <Label text="X"
                                   style="-fx-font-size:10; -fx-font-weight:bold; -fx-min-width:10;"/>

                            <Slider fx:id="sliderDx"
                                    min="-1000" max="1000" value="0"
                                    HBox.hgrow="ALWAYS"
                                    blockIncrement="10"/>

                            <Label fx:id="dxValueLabel"
                                   text="0 px"
                                   style="-fx-font-size:11;
                                          -fx-font-weight:bold;
                                          -fx-text-fill:#c86442;
                                          -fx-min-width:56;"/>
                        </HBox>

                        <!-- Y axis -->
                        <HBox spacing="8" alignment="CENTER_LEFT"
                              style="-fx-padding:0 0 10 0;">

                            <Label text="Y"
                                   style="-fx-font-size:10; -fx-font-weight:bold; -fx-min-width:10;"/>

                            <Slider fx:id="sliderDy"
                                    min="-1000" max="1000" value="0"
                                    HBox.hgrow="ALWAYS"
                                    blockIncrement="10"/>

                            <Label fx:id="dyValueLabel"
                                   text="0 px"
                                   style="-fx-font-size:11;
                                          -fx-font-weight:bold;
                                          -fx-text-fill:#c86442;
                                          -fx-min-width:56;"/>
                        </HBox>

                        <!-- Manual coordinate input -->
                        <HBox spacing="6" alignment="CENTER_LEFT">

                            <Label text="X"
                                   style="-fx-font-size:10; -fx-font-weight:bold;"/>

                            <TextField fx:id="fieldDx"
                                       prefWidth="60" prefHeight="28"
                                       promptText="0"/>

                            <Label text="Y"
                                   style="-fx-font-size:10; -fx-font-weight:bold;"/>

                            <TextField fx:id="fieldDy"
                                       prefWidth="60" prefHeight="28"
                                       promptText="0"/>

                            <Button text="Apply"
                                    onAction="#applyTranslate"
                                    prefHeight="28"
                                    HBox.hgrow="ALWAYS"
                                    maxWidth="Infinity"
                                    style="-fx-font-size:10;
                                           -fx-font-weight:bold;
                                           -fx-background-color:#c86442;
                                           -fx-text-fill:white;
                                           -fx-background-radius:5;
                                           -fx-cursor:hand;"/>
                        </HBox>
                    </VBox>

                    <!-- ══════════════════════════════════════════
                         BOTTOM ACTION ROW
                    ══════════════════════════════════════════ -->
                    <HBox spacing="6"
                          style="-fx-padding:14 16 16 16;">

                        <Button text="Undo"
                                onAction="#handleUndo"
                                maxWidth="Infinity"
                                HBox.hgrow="ALWAYS"
                                prefHeight="32"
                                style="-fx-font-size:11;
                                       -fx-background-color:#ede6dc;
                                       -fx-text-fill:#4a3a28;
                                       -fx-background-radius:6;
                                       -fx-cursor:hand;"/>

                        <Button text="Reset all"
                                onAction="#handleReset"
                                maxWidth="Infinity"
                                HBox.hgrow="ALWAYS"
                                prefHeight="32"
                                style="-fx-font-size:11;
                                       -fx-background-color:#ede6dc;
                                       -fx-text-fill:#4a3a28;
                                       -fx-background-radius:6;
                                       -fx-cursor:hand;"/>
                    </HBox>

                    <!-- Image info readout -->
                    <Label fx:id="imageInfoLabel"
                           text=""
                           wrapText="true"
                           style="-fx-font-size:10;
                                  -fx-text-fill:#9a8a78;
                                  -fx-font-family:'Consolas',monospace;
                                  -fx-padding:0 16 12 16;"/>

                </VBox>
            </ScrollPane>
        </VBox>
    </HBox>
</VBox>
