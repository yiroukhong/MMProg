<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.Slider?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.wig3003.photoapp.dip.geometric.DipExtractController"
            style="-fx-background-color:#1a1612;">

    <top>
        <HBox spacing="8"
              alignment="CENTER_LEFT"
              style="-fx-padding:0 14;
                     -fx-min-height:46;
                     -fx-max-height:46;
                     -fx-background-color:#161210;
                     -fx-border-color:#2c2620;
                     -fx-border-width:0 0 1 0;">

            <Button text="Load File"
                    onAction="#loadImage"
                    style="-fx-font-size:11;
                           -fx-font-weight:bold;
                           -fx-background-color:#c86442;
                           -fx-text-fill:white;
                           -fx-padding:6 16;
                           -fx-background-radius:6;
                           -fx-cursor:hand;"/>

            <Button text="Load Library"
                    onAction="#loadFromLibrary"
                    style="-fx-font-size:11;
                           -fx-font-weight:bold;
                           -fx-background-color:#7a5c3a;
                           -fx-text-fill:white;
                           -fx-padding:6 14;
                           -fx-background-radius:6;
                           -fx-cursor:hand;"/>

            <Separator orientation="VERTICAL"
                       style="-fx-opacity:0.25;"/>

            <Button text="Save to Library"
                    onAction="#saveToLibrary"
                    style="-fx-font-size:11;
                           -fx-background-color:rgba(255,255,255,0.08);
                           -fx-text-fill:rgba(240,230,216,0.8);
                           -fx-padding:6 14;
                           -fx-background-radius:6;
                           -fx-cursor:hand;"/>

            <Button text="Save to Device"
                    onAction="#saveToDevice"
                    style="-fx-font-size:11;
                           -fx-background-color:rgba(255,255,255,0.08);
                           -fx-text-fill:rgba(240,230,216,0.8);
                           -fx-padding:6 14;
                           -fx-background-radius:6;
                           -fx-cursor:hand;"/>

            <Button text="Save Both"
                    onAction="#saveBoth"
                    style="-fx-font-size:11;
                           -fx-background-color:rgba(255,255,255,0.08);
                           -fx-text-fill:rgba(240,230,216,0.8);
                           -fx-padding:6 14;
                           -fx-background-radius:6;
                           -fx-cursor:hand;"/>

            <Separator orientation="VERTICAL"
                       style="-fx-opacity:0.25;"/>

            <Label text="Tolerance"
                   style="-fx-font-size:10;
                          -fx-font-weight:bold;
                          -fx-text-fill:rgba(240,230,216,0.6);"/>

            <Slider fx:id="toleranceSlider"
                    min="0"
                    max="80"
                    value="24"
                    prefWidth="140"
                    blockIncrement="1"
                    style="-fx-padding:0 4;"/>

            <Label fx:id="toleranceLabel"
                   text="24"
                   style="-fx-font-size:11;
                          -fx-font-weight:bold;
                          -fx-text-fill:#c86442;
                          -fx-min-width:28;
                          -fx-font-family:'Consolas',monospace;"/>

            <Region HBox.hgrow="ALWAYS"/>

            <Button text="?"
                    onAction="#showHelp"
                    style="-fx-font-size:12;
                           -fx-font-weight:bold;
                           -fx-background-color:rgba(255,255,255,0.06);
                           -fx-text-fill:rgba(240,230,216,0.55);
                           -fx-padding:4 10;
                           -fx-background-radius:20;
                           -fx-border-color:rgba(255,255,255,0.08);
                           -fx-border-radius:20;
                           -fx-cursor:hand;
                           -fx-min-width:30;"/>
        </HBox>
    </top>

    <center>
        <HBox spacing="0"
              style="-fx-background-color:#111111;">

            <StackPane fx:id="sourcePane"
                       HBox.hgrow="ALWAYS"
                       minWidth="0"
                       style="-fx-background-color:#111111;
                              -fx-border-color:#2c2620;
                              -fx-border-width:0 1 0 0;
                              -fx-cursor:crosshair;">

                <ImageView fx:id="imageView"
                           preserveRatio="true"
                           smooth="true"
                           pickOnBounds="false"/>

                <VBox fx:id="sourcePlaceholder"
                      alignment="CENTER"
                      spacing="10"
                      mouseTransparent="true">

                    <Label text="Load"
                           style="-fx-font-size:30;
                                  -fx-text-fill:rgba(255,255,255,0.08);"/>

                    <Label text="Load an image"
                           style="-fx-font-size:13;
                                  -fx-text-fill:rgba(255,255,255,0.15);
                                  -fx-font-family:'Georgia',serif;"/>
                </VBox>
            </StackPane>

            <StackPane fx:id="resultPane"
                       HBox.hgrow="ALWAYS"
                       minWidth="0"
                       style="-fx-background-color:#111111;">

                <StackPane mouseTransparent="true"
                           style="-fx-background-color:#111111,
                                  linear-gradient(45deg,#1e1e1e 25%,transparent 25%),
                                  linear-gradient(-45deg,#1e1e1e 25%,transparent 25%),
                                  linear-gradient(45deg,transparent 75%,#1e1e1e 75%),
                                  linear-gradient(-45deg,transparent 75%,#1e1e1e 75%);
                                  -fx-background-size:auto,18px 18px,18px 18px,18px 18px,18px 18px;
                                  -fx-background-position:0 0,0 0,0 9px,9px -9px,-9px 0px;"/>

                <ImageView fx:id="resultView"
                           preserveRatio="true"
                           smooth="true"
                           pickOnBounds="false"/>

                <VBox fx:id="resultPlaceholder"
                      alignment="CENTER"
                      spacing="10"
                      mouseTransparent="true">

                    <Label text="Result"
                           style="-fx-font-size:24;
                                  -fx-text-fill:rgba(255,255,255,0.06);"/>

                    <Label text="Click the object to extract it"
                           style="-fx-font-size:13;
                                  -fx-text-fill:rgba(255,255,255,0.15);
                                  -fx-font-family:'Georgia',serif;"/>
                </VBox>
            </StackPane>
        </HBox>
    </center>
</BorderPane>
