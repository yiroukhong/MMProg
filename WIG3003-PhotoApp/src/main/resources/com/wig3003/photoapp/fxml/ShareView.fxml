<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.wig3003.photoapp.social.ShareController"
            styleClass="root-pane">

    <!-- ═══════════════════════════════════════════════════════
         TOP — content header
    ═══════════════════════════════════════════════════════ -->
    <top>
        <HBox styleClass="content-header" alignment="CENTER_LEFT" spacing="10">
            <Label text="Share by email" styleClass="page-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button fx:id="cancelBtn" text="Cancel" onAction="#handleCancel"
                    styleClass="btn-secondary"/>
            <Button fx:id="sendBtn" text="Send" onAction="#handleSend"
                    styleClass="btn-primary" disable="true">
                <graphic>
                    <FontIcon iconLiteral="bi-envelope" iconSize="14" iconColor="WHITE"/>
                </graphic>
            </Button>
        </HBox>
    </top>

    <!-- ═══════════════════════════════════════════════════════
         CENTER — compose area + toast overlay
    ═══════════════════════════════════════════════════════ -->
    <center>
        <StackPane>

            <ScrollPane fitToWidth="true"
                        style="-fx-background-color:#FBF8F3;
                               -fx-background:#FBF8F3;
                               -fx-border-color:transparent;
                               -fx-focus-color:transparent;
                               -fx-faint-focus-color:transparent;">

                <VBox spacing="0" maxWidth="860" alignment="TOP_CENTER"
                      style="-fx-padding:0 80 40 80;">

                    <!-- ── ERROR BANNER ── -->
                    <VBox fx:id="errorBanner" visible="false" managed="false"
                          style="-fx-background-color:#FDE8E8;
                                 -fx-border-color:#F5C0C0;
                                 -fx-border-radius:8;
                                 -fx-background-radius:8;
                                 -fx-padding:12 16 12 16;">
                        <VBox.margin><Insets bottom="12"/></VBox.margin>

                        <HBox spacing="10" alignment="CENTER_LEFT">
                            <Label text="✕"
                                   style="-fx-font-size:14; -fx-text-fill:#B0432B;"/>
                            <VBox spacing="4">
                                <Label fx:id="errorTitle"
                                       text="Couldn't send - attachment too large"
                                       style="-fx-font-size:13; -fx-font-weight:bold; -fx-text-fill:#B0432B;"/>
                                <Label fx:id="errorBody"
                                       text="Your mail provider rejected files over 25 MB."
                                       style="-fx-font-size:11; -fx-text-fill:#B0432B;"
                                       wrapText="true"/>
                            </VBox>
                        </HBox>

                        <HBox spacing="8" style="-fx-padding:8 0 0 0;">
                            <Button fx:id="retrySendBtn" text="Retry send"
                                    onAction="#handleSend"
                                    styleClass="btn-secondary"/>
                            <Button fx:id="sendWithoutLargeBtn"
                                    text="Send without large files"
                                    onAction="#handleSendWithoutLarge"
                                    styleClass="btn-secondary"
                                    visible="false" managed="false"/>
                        </HBox>
                    </VBox>

                    <!-- ── COMPOSE CARD ── -->
                    <VBox style="-fx-background-color:white;
                                 -fx-border-color:#DDD2BC;
                                 -fx-border-radius:12;
                                 -fx-background-radius:12;">
                        <VBox.margin><Insets top="24"/></VBox.margin>

                        <!-- FROM ROW -->
                        <HBox spacing="16" alignment="CENTER_LEFT"
                              style="-fx-padding:14 20 14 20;
                                     -fx-border-color:transparent transparent #ECE4D3 transparent;
                                     -fx-border-width:0 0 1 0;">
                            <Label text="FROM"
                                   style="-fx-font-size:10; -fx-font-weight:bold; -fx-text-fill:#9C907D; -fx-min-width:60;"/>
                            <Label fx:id="fromLabel" text="Loading…"
                                   style="-fx-font-size:13; -fx-text-fill:#1F1B16;"/>
                            <Label fx:id="fromEmailLabel" text=""
                                   style="-fx-font-size:13; -fx-text-fill:#9C907D;"/>
                        </HBox>

                        <!-- TO ROW -->
                        <HBox spacing="12" alignment="TOP_LEFT"
                              style="-fx-padding:10 20 10 20;
                                     -fx-border-color:transparent transparent #ECE4D3 transparent;
                                     -fx-border-width:0 0 1 0;">
                            <Label text="TO"
                                   style="-fx-font-size:10; -fx-font-weight:bold; -fx-text-fill:#9C907D; -fx-min-width:60; -fx-padding:6 0 0 0;"/>
                            <VBox fx:id="recipientTagBox" spacing="6" HBox.hgrow="ALWAYS">
                                <TextField fx:id="recipientInput"
                                           promptText="Add a recipient"
                                           prefHeight="28"
                                           onAction="#handleAddRecipient"
                                           style="-fx-background-color:transparent;
                                                  -fx-border-color:transparent;
                                                  -fx-font-size:13;
                                                  -fx-text-fill:#1F1B16;
                                                  -fx-prompt-text-fill:#9C907D;
                                                  -fx-focus-color:transparent;
                                                  -fx-faint-focus-color:transparent;"/>
                            </VBox>
                        </HBox>

                        <!-- SUBJECT ROW -->
                        <HBox spacing="16" alignment="CENTER_LEFT"
                              style="-fx-padding:14 20 14 20;
                                     -fx-border-color:transparent transparent #ECE4D3 transparent;
                                     -fx-border-width:0 0 1 0;">
                            <Label text="SUBJECT"
                                   style="-fx-font-size:10; -fx-font-weight:bold; -fx-text-fill:#9C907D; -fx-min-width:60;"/>
                            <TextField fx:id="subjectField"
                                       promptText="Subject"
                                       HBox.hgrow="ALWAYS"
                                       style="-fx-background-color:transparent;
                                              -fx-border-color:transparent;
                                              -fx-font-size:13;
                                              -fx-text-fill:#1F1B16;
                                              -fx-prompt-text-fill:#9C907D;
                                              -fx-focus-color:transparent;
                                              -fx-faint-focus-color:transparent;"/>
                        </HBox>

                        <!-- BODY AREA -->
                        <VBox style="-fx-padding:14 20 14 20;
                                     -fx-border-color:transparent transparent #ECE4D3 transparent;
                                     -fx-border-width:0 0 1 0;">
                            <TextArea fx:id="bodyArea"
                                      promptText="Write a message…"
                                      prefHeight="180" wrapText="true"
                                      style="-fx-background-color:transparent;
                                             -fx-border-color:transparent;
                                             -fx-font-size:13;
                                             -fx-text-fill:#1F1B16;
                                             -fx-prompt-text-fill:#9C907D;
                                             -fx-focus-color:transparent;
                                             -fx-faint-focus-color:transparent;"/>
                        </VBox>

                        <!-- ATTACHMENTS SECTION -->
                        <VBox fx:id="attachmentsSection"
                              style="-fx-padding:14 20 14 20;" spacing="8">
                            <HBox alignment="CENTER_LEFT" spacing="8">
                                <Label fx:id="attachmentsHeaderLabel" text="ATTACHMENTS"
                                       style="-fx-font-size:10; -fx-font-weight:bold; -fx-text-fill:#9C907D;"/>
                                <Label fx:id="attachmentsSummaryLabel" text=""
                                       style="-fx-font-size:10; -fx-text-fill:#9C907D;"/>
                            </HBox>
                            <VBox fx:id="attachmentListBox" spacing="6"/>
                            <Button text="+ Attach file" onAction="#handleAttachFile"
                                    style="-fx-background-color:transparent;
                                           -fx-border-color:transparent;
                                           -fx-text-fill:#C8623F;
                                           -fx-font-size:11;
                                           -fx-cursor:hand;
                                           -fx-padding:4 0 4 0;"/>
                        </VBox>

                    </VBox>
                </VBox>
            </ScrollPane>

            <!-- SUCCESS TOAST — overlaid at bottom of center pane -->
            <HBox fx:id="successToast" visible="false" managed="false"
                  StackPane.alignment="BOTTOM_CENTER"
                  alignment="CENTER" spacing="10"
                  style="-fx-background-color:#1F1B16;
                         -fx-background-radius:8;
                         -fx-padding:12 20 12 20;">
                <StackPane.margin><Insets bottom="20"/></StackPane.margin>
                <Label fx:id="toastLabel" text=""
                       style="-fx-font-size:13; -fx-font-weight:bold; -fx-text-fill:white;"/>
            </HBox>

        </StackPane>
    </center>

    <!-- ═══════════════════════════════════════════════════════
         BOTTOM — status bar
    ═══════════════════════════════════════════════════════ -->
    <bottom>
        <HBox alignment="CENTER_LEFT" spacing="16"
              style="-fx-padding:8 80 8 80;
                     -fx-border-color:#ECE4D3 transparent transparent transparent;
                     -fx-border-width:1 0 0 0;
                     -fx-background-color:#FBF8F3;">
            <Label text="Sent via your default mail client"
                   style="-fx-font-size:11; -fx-text-fill:#9C907D;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="uploadStatusLabel" text=""
                   style="-fx-font-size:11; -fx-text-fill:#9C907D;"/>
        </HBox>
    </bottom>

</BorderPane>
