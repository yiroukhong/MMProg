<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.ScrollPane?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.control.ToggleButton?>
<?import javafx.scene.control.ToggleGroup?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.TilePane?>
<?import javafx.scene.layout.VBox?>
<?import org.kordamp.ikonli.javafx.FontIcon?>
<?import javafx.scene.canvas.Canvas?>
<?import javafx.scene.control.ColorPicker?>
<?import javafx.scene.control.Slider?>

<BorderPane xmlns="http://javafx.com/javafx/21"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.wig3003.photoapp.ui.MainController"
            styleClass="root-pane">

    <fx:define>
        <ToggleGroup fx:id="filterGroup"/>
    </fx:define>

    <!-- ═══════════════════════════════════════════════════════
         LEFT SIDEBAR
         ═══════════════════════════════════════════════════════ -->
    <left>
        <VBox styleClass="sidebar">

            <!-- Brand -->
            <HBox styleClass="brand-row">
                <StackPane styleClass="brand-icon-box">
                    <Label text="V" styleClass="brand-icon"/>
                </StackPane>
                <Label text="Vi-Flow" styleClass="brand-name"/>
            </HBox>

            <!-- LIBRARY section -->
            <Label text="LIBRARY" styleClass="nav-section-label"/>

            <HBox fx:id="navLibrary" styleClass="nav-item"
                  alignment="CENTER_LEFT" spacing="12"
                  onMouseClicked="#handleNavLibrary">
                <VBox.margin><Insets top="2" right="8" bottom="2" left="8"/></VBox.margin>
                <FontIcon iconLiteral="bi-columns" iconSize="16" styleClass="nav-icon-label"/>
                <Label text="Library" styleClass="nav-label">
                    <HBox.hgrow>ALWAYS</HBox.hgrow>
                </Label>
                <Label fx:id="countLibrary" text="0" styleClass="nav-count"/>
            </HBox>

            <HBox fx:id="navFavorites" styleClass="nav-item"
                  alignment="CENTER_LEFT" spacing="12"
                  onMouseClicked="#handleNavFavorites">
                <VBox.margin><Insets top="2" right="8" bottom="2" left="8"/></VBox.margin>
                <FontIcon iconLiteral="bi-heart" iconSize="16" styleClass="nav-icon-label"/>
                <Label text="Favorites" styleClass="nav-label">
                    <HBox.hgrow>ALWAYS</HBox.hgrow>
                </Label>
                <Label fx:id="countFavorites" text="0" styleClass="nav-count"/>
            </HBox>

            <HBox fx:id="navAnnotated" styleClass="nav-item"
                  alignment="CENTER_LEFT" spacing="12"
                  onMouseClicked="#handleNavAnnotated">
                <VBox.margin><Insets top="2" right="8" bottom="2" left="8"/></VBox.margin>
                <FontIcon iconLiteral="bi-pencil-square" iconSize="16" styleClass="nav-icon-label"/>
                <Label text="Annotated" styleClass="nav-label">
                    <HBox.hgrow>ALWAYS</HBox.hgrow>
                </Label>
                <Label fx:id="countAnnotated" text="0" styleClass="nav-count"/>
            </HBox>

            <!-- STUDIO section -->
            <Label text="STUDIO" styleClass="nav-section-label"/>

            <HBox styleClass="nav-item" onMouseClicked="#handleNavEdit">
                <VBox.margin><Insets top="2" right="8" bottom="2" left="8"/></VBox.margin>
                <FontIcon iconLiteral="bi-circle-square" iconSize="16" styleClass="nav-icon-label"/>
                <Label text="Edit" styleClass="nav-label">
                    <HBox.hgrow>ALWAYS</HBox.hgrow>
                </Label>
            </HBox>

            <HBox fx:id="navMosaic" styleClass="nav-item" onMouseClicked="#handleNavMosaic">
                <VBox.margin><Insets top="2" right="8" bottom="2" left="8"/></VBox.margin>
                <FontIcon iconLiteral="bi-grid" iconSize="16" styleClass="nav-icon-label"/>
                <Label text="Mosaic" styleClass="nav-label">
                    <HBox.hgrow>ALWAYS</HBox.hgrow>
                </Label>
                <Label text="0" styleClass="nav-count"/>
            </HBox>

            <HBox fx:id="navVideo" styleClass="nav-item" onMouseClicked="#handleNavVideo">
                <VBox.margin><Insets top="2" right="8" bottom="2" left="8"/></VBox.margin>
                <FontIcon iconLiteral="bi-camera-video" iconSize="16" styleClass="nav-icon-label"/>
                <Label text="Video" styleClass="nav-label">
                    <HBox.hgrow>ALWAYS</HBox.hgrow>
                </Label>
                <Label text="0" styleClass="nav-count"/>
            </HBox>

            <HBox fx:id="navShare" styleClass="nav-item" onMouseClicked="#handleNavShare">
                <VBox.margin><Insets top="2" right="8" bottom="2" left="8"/></VBox.margin>
                <FontIcon iconLiteral="bi-share" iconSize="16" styleClass="nav-icon-label"/>
                <Label text="Share" styleClass="nav-label">
                    <HBox.hgrow>ALWAYS</HBox.hgrow>
                </Label>
            </HBox>
            

        </VBox>
    </left>

    <!-- ═══════════════════════════════════════════════════════
         CENTER — Library view  ↔  Detail view
         ═══════════════════════════════════════════════════════ -->
    <center>
        <StackPane>

            <!-- ─── LIBRARY VIEW ─────────────────────────────── -->
            <VBox fx:id="libraryView" styleClass="content-area">

                <!-- Header bar -->
                <HBox styleClass="content-header">
                    <Label text="Your Library" styleClass="page-title"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <TextField fx:id="searchField" styleClass="search-field"
                               promptText="Search by name, date, or tag"
                               onAction="#handleSearch"/>
                    <Button text="Import" styleClass="btn-secondary"
                                    onAction="#handleImport">
                        <graphic>
                            <FontIcon iconLiteral="bi-box-arrow-in-down" iconSize="16"/>
                        </graphic>
                    </Button>
                    <Button text="+ New Mosaic" styleClass="btn-primary"
                            onAction="#handleNewMosaic"/>
                </HBox>

                <!-- Filter pills -->
                <HBox styleClass="filter-bar">
                    <ToggleButton fx:id="filterAll" text="All · 0"
                                  styleClass="filter-pill"
                                  selected="true"
                                  toggleGroup="$filterGroup"
                                  onAction="#handleFilter"/>
                    <ToggleButton fx:id="filterAnnotated" text="Annotated · 0"
                                  styleClass="filter-pill"
                                  toggleGroup="$filterGroup"
                                  onAction="#handleFilter"/>
                    <ToggleButton fx:id="filterFavorites" text="Favorites · 0"
                                  styleClass="filter-pill"
                                  toggleGroup="$filterGroup"
                                  onAction="#handleFilter"/>
                    <ToggleButton fx:id="filterRecent" text="Recent"
                                  styleClass="filter-pill"
                                  toggleGroup="$filterGroup"
                                  onAction="#handleFilter"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="selectedCountLabel" text=""
                           styleClass="selected-count-label"/>
                </HBox>

                <!-- Grid / Empty state -->
                <StackPane VBox.vgrow="ALWAYS">

                    <!-- Thumbnail grid (hidden until images load) -->
                    <ScrollPane fx:id="gridScrollPane"
                                styleClass="grid-scroll-pane"
                                fitToWidth="true"
                                visible="false" managed="false">
                        <TilePane fx:id="photoGrid"
                                  styleClass="photo-grid"
                                  prefColumns="5"
                                  hgap="8" vgap="8"/>
                    </ScrollPane>

                    <!-- Empty state -->
                    <VBox fx:id="emptyState" styleClass="empty-state"
                          alignment="CENTER" spacing="12">
                        <StackPane styleClass="empty-icon-bg" alignment="CENTER">
                            <FontIcon iconLiteral="bi-images" iconSize="48" styleClass="empty-icon"/>
                        </StackPane>
                        <Label text="No photos yet." styleClass="empty-title"/>
                        <Label styleClass="empty-body" textAlignment="CENTER"
                               text="Drop a folder anywhere on this window, or use&#10;import to point Vi-Flow at your photo library"
                               wrapText="true"/>
                        <HBox styleClass="empty-buttons">
                            <Button text="Browse" styleClass="btn-secondary"
                                    onAction="#handleBrowse">
                                <graphic>
                                    <FontIcon iconLiteral="bi-folder" iconSize="16"/>
                                </graphic>
                            </Button>
                            <Button text="Import folder" styleClass="btn-primary"
                                    onAction="#handleImport">
                                <graphic>
                                    <FontIcon iconLiteral="bi-box-arrow-in-down" iconSize="16" iconColor="WHITE" />
                                </graphic>
                            </Button>
                        </HBox>
                    </VBox>

                </StackPane>
            </VBox>

            <!-- ─── DETAIL VIEW ───────────────────────────────── -->
            <VBox fx:id="detailView" styleClass="detail-view"
                  visible="false" managed="false"
                  VBox.vgrow="ALWAYS">

                <!-- Detail header -->
                <!-- Detail header -->
                <HBox styleClass="detail-header">
                    <Label fx:id="detailFilename" text=""
                           styleClass="detail-filename"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Label fx:id="detailDimensions" text=""
                           styleClass="detail-dimensions"/>
                    <Button fx:id="heartButton" styleClass="heart-btn"
                            onAction="#handleToggleFavourite">
                    </Button>
                    <Button text="Share" styleClass="btn-secondary"
                            onAction="#handleShare"/>
                </HBox>

                <!-- Full-res image area (dark canvas) -->
                <StackPane fx:id="detailImageArea"
                        styleClass="detail-image-area"
                        VBox.vgrow="ALWAYS"
                        minHeight="300"
                        maxHeight="600">
                    <ImageView fx:id="detailImageView"
                            preserveRatio="true" smooth="true"
                            pickOnBounds="true"/>
                    <!-- Canvas sits on top — text + heart drawn here -->
                    <Canvas fx:id="annotationCanvas"/>
                </StackPane>

                <!-- Annotation panel -->
            <VBox styleClass="annotation-panel" spacing="8" VBox.vgrow="NEVER">
                <padding><Insets top="10" right="16" bottom="12" left="16"/></padding>

                <Label text="ANNOTATE IMAGE" styleClass="annotation-section-label"/>

                <!-- Text input row -->
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="Text" minWidth="70" maxWidth="70"
                        style="-fx-text-fill: #888; -fx-font-size: 12px;"/>
                    <TextField fx:id="annotationTextField"
                            promptText="Type annotation text..."
                            HBox.hgrow="ALWAYS"/>
                </HBox>

                <!-- Font size row -->
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="Font size" minWidth="70" maxWidth="70"
                        style="-fx-text-fill: #888; -fx-font-size: 12px;"/>
                    <Slider fx:id="fontSizeSlider" min="10" max="72" value="18"
                            HBox.hgrow="ALWAYS"/>
                    <Label fx:id="fontSizeLabel" text="18 pt"
                        minWidth="36" maxWidth="36"
                        style="-fx-font-size: 12px; -fx-text-fill: #666;"/>
                </HBox>

                <!-- Font color row -->
                <HBox spacing="10" alignment="CENTER_LEFT">
                    <Label text="Font color" minWidth="70" maxWidth="70"
                        style="-fx-text-fill: #888; -fx-font-size: 12px;"/>
                        <ColorPicker fx:id="fontColorPicker" prefWidth="180" minWidth="180" maxWidth="180" prefHeight="32"/>
                </HBox>

                <!-- Buttons row -->
                <HBox alignment="CENTER_RIGHT" spacing="10">
                    <padding><Insets top="4"/></padding>
                    <Label fx:id="annotationFeedbackLabel" text=""
                        style="-fx-font-size: 12px; -fx-text-fill: #6B6051; -fx-font-style: italic;">
                        <HBox.hgrow>ALWAYS</HBox.hgrow>
                    </Label>
                    <Button text="Clear text" styleClass="btn-secondary"
                            onAction="#handleClearText" prefWidth="100"/>
                    <Button text="Save" styleClass="btn-primary"
                            onAction="#handleSaveAndBack" prefWidth="100"/>
                </HBox>
                </VBox>

            </VBox>
                        <!-- ─── MOSAIC VIEW ───────────────────────────── -->
            <fx:include fx:id="mosaicView"
                        source="MosaicView.fxml"
                        visible="false" managed="false"/>

            <!-- ─── VIDEO VIEW ───────────────────────────── -->
            <fx:include fx:id="videoView"
                        source="VideoView.fxml"
                        visible="false" managed="false"/>

            <!-- ─── SHARE VIEW ──────────────────────────── -->
            <fx:include fx:id="shareView"
                        source="ShareView.fxml"
                        visible="false" managed="false"/>

        </StackPane>
    </center>

</BorderPane>
